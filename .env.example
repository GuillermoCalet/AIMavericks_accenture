# ---------------------------------------------------------------------------
# AI Fashion Copilot — environment configuration
# Choose Gemini for a faster cloud demo or Ollama for fully local inference.
# ---------------------------------------------------------------------------

# --- Provider selection ---
LLM_PROVIDER=ollama

# --- Ollama (local, no API key) ---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=gemma3:4b
# Legacy fallback: if set, OLLAMA_MODEL is used for both roles unless one of
# the role-specific variables above overrides it.
# OLLAMA_MODEL=
# Vision requests can be slow on CPU. Increase this if necessary.
OLLAMA_TIMEOUT_MS=300000
# Shared context window for local text and vision inference.
OLLAMA_NUM_CTX=8192
# Keep each recently used model loaded between pipeline stages.
OLLAMA_KEEP_ALIVE=10m

# --- Gemini (cloud, fast demo mode) ---
# Set LLM_PROVIDER=gemini and provide a backend-only key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=60000

# --- Backend API ---
API_PORT=3001
# Comma-separated list of origins allowed by CORS (frontend dev server).
CORS_ORIGINS=http://localhost:5173
# Max image upload size (per file) in megabytes.
MAX_UPLOAD_SIZE_MB=8

# --- Python OR-Tools solver service ---
SOLVER_URL=http://localhost:8000
SOLVER_PORT=8000
# CP-SAT wall-clock limit per request (seconds).
SOLVER_TIME_LIMIT_S=5
# Deterministic seed for reproducible optimization.
SOLVER_SEED=42

# --- Catalog ---
CATALOG_CSV_PATH=./Data - Copy.csv
CATALOG_DB_PATH=./data/catalog.duckdb
# Max candidate products fed to the solver per category.
MAX_CANDIDATES_PER_CATEGORY=20
# Folder with local product images named <id>.png (matches the CSV id). Used to
# guarantee the recommendation shows the correct image; falls back to the CDN.
PRODUCT_IMAGES_DIR=./Flipkart

# --- Frontend (safe to expose; NO secrets here) ---
# Where the browser reaches the backend API.
VITE_API_BASE_URL=http://localhost:3001
